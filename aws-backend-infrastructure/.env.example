# ============================================================================
# AWS Backend Infrastructure - Environment Configuration
# ============================================================================
# This file contains all required and optional environment variables for
# deploying the AWS backend infrastructure.
#
# Requirements: 13.1, 13.5
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your AWS account details
# 3. Customize optional settings as needed
# 4. Never commit .env to version control
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED: AWS Configuration
# ----------------------------------------------------------------------------
# Your AWS account ID (12-digit number)
# Find it in AWS Console > Account Settings or run: aws sts get-caller-identity
AWS_ACCOUNT_ID=123456789012

# AWS region for deployment (e.g., us-east-1, us-west-2, eu-west-1)
AWS_REGION=us-east-1

# ----------------------------------------------------------------------------
# REQUIRED: Environment
# ----------------------------------------------------------------------------
# Deployment environment: dev, staging, or prod
# This determines which configuration file is loaded from lib/config/
ENVIRONMENT=dev

# ----------------------------------------------------------------------------
# OPTIONAL: Domain Configuration
# ----------------------------------------------------------------------------
# Custom domain name for API Gateway (leave commented for default CloudFront domain)
# DOMAIN_NAME=api.farmplatform.example.com

# ACM certificate ARN for custom domain (required if DOMAIN_NAME is set)
# CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/abc123

# ----------------------------------------------------------------------------
# OPTIONAL: Network Configuration
# ----------------------------------------------------------------------------
# Custom VPC CIDR block (default: 10.0.0.0/16)
# VPC_CIDR=10.0.0.0/16

# Number of availability zones (default: 2, max: 3)
# AZ_COUNT=2

# ----------------------------------------------------------------------------
# OPTIONAL: Feature Flags
# ----------------------------------------------------------------------------
# Enable AWS WAF for API Gateway (default: false for dev, true for prod)
# ENABLE_WAF=false

# Enable AWS X-Ray tracing (default: true)
# ENABLE_XRAY=true

# Enable VPC endpoints for AWS services (default: true)
# ENABLE_VPC_ENDPOINTS=true

# Enable cross-region replication for S3 (default: false for dev/staging, true for prod)
# ENABLE_S3_REPLICATION=false

# ----------------------------------------------------------------------------
# OPTIONAL: Secrets Manager Configuration
# ----------------------------------------------------------------------------
# Prefix for secrets in AWS Secrets Manager (default: {environment}/)
# SECRETS_PREFIX=dev/

# Enable automatic secret rotation (default: false for dev, true for prod)
# ENABLE_SECRET_ROTATION=false

# Secret rotation interval in days (default: 30)
# SECRET_ROTATION_DAYS=30

# ----------------------------------------------------------------------------
# OPTIONAL: Database Configuration
# ----------------------------------------------------------------------------
# DynamoDB table name prefix (default: {environment}-)
# DYNAMODB_PREFIX=dev-

# Enable DynamoDB point-in-time recovery (default: false for dev, true for staging/prod)
# DYNAMODB_PITR=false

# DynamoDB backup retention in days (default: 7 for dev, 35 for prod)
# DYNAMODB_BACKUP_RETENTION=7

# ----------------------------------------------------------------------------
# OPTIONAL: Lambda Configuration
# ----------------------------------------------------------------------------
# Default Lambda memory size in MB (default: 256 for dev, 512 for prod)
# LAMBDA_MEMORY_SIZE=256

# Default Lambda timeout in seconds (default: 30 for dev, 60 for prod)
# LAMBDA_TIMEOUT=30

# Lambda log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LAMBDA_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# OPTIONAL: Monitoring Configuration
# ----------------------------------------------------------------------------
# CloudWatch log retention in days (default: 7 for dev, 90 for prod)
# LOG_RETENTION_DAYS=7

# Enable CloudWatch alarms (default: false for dev, true for staging/prod)
# ENABLE_ALARMS=false

# SNS topic ARN for alarm notifications (required if ENABLE_ALARMS=true)
# ALARM_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:alerts

# ----------------------------------------------------------------------------
# OPTIONAL: API Gateway Configuration
# ----------------------------------------------------------------------------
# API Gateway throttle rate limit (requests per second)
# API_RATE_LIMIT=100

# API Gateway burst limit
# API_BURST_LIMIT=200

# Enable API Gateway caching (default: false for dev, true for staging/prod)
# ENABLE_API_CACHE=false

# API Gateway cache TTL in seconds (default: 300)
# API_CACHE_TTL=300

# ----------------------------------------------------------------------------
# OPTIONAL: Cognito Configuration
# ----------------------------------------------------------------------------
# Cognito MFA configuration: OFF, OPTIONAL, REQUIRED (default: OPTIONAL for dev, REQUIRED for prod)
# COGNITO_MFA=OPTIONAL

# Minimum password length (default: 8 for dev, 12 for prod)
# COGNITO_PASSWORD_MIN_LENGTH=8

# ----------------------------------------------------------------------------
# OPTIONAL: Cost Allocation Tags
# ----------------------------------------------------------------------------
# Project name for cost allocation (default: FarmPlatform)
# PROJECT_NAME=FarmPlatform

# Cost center for billing (default: Engineering)
# COST_CENTER=Engineering

# Team or department name
# TEAM_NAME=Backend

# ----------------------------------------------------------------------------
# OPTIONAL: External Service Configuration
# ----------------------------------------------------------------------------
# External API keys (store actual values in AWS Secrets Manager, not here)
# These are just placeholders to indicate which secrets need to be created

# Weather API key (stored in Secrets Manager as {SECRETS_PREFIX}weather-api-key)
# WEATHER_API_KEY=placeholder

# Market data API key (stored in Secrets Manager as {SECRETS_PREFIX}market-api-key)
# MARKET_API_KEY=placeholder

# ----------------------------------------------------------------------------
# OPTIONAL: Development/Testing Configuration
# ----------------------------------------------------------------------------
# Enable debug mode (verbose logging, additional validation)
# DEBUG_MODE=false

# Skip certain validations during deployment (use with caution)
# SKIP_VALIDATIONS=false

# Seed database with test data after deployment
# SEED_TEST_DATA=false

# ----------------------------------------------------------------------------
# Notes:
# - All REQUIRED variables must be set before deployment
# - OPTIONAL variables have sensible defaults based on ENVIRONMENT
# - Sensitive values (API keys, passwords) should be stored in AWS Secrets Manager
# - See README.md for detailed setup instructions
# - See lib/config/ for environment-specific configurations
# ============================================================================
